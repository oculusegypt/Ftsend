{
  "name": "@p2p-drop/mobile",
  "version": "1.0.0",
  "description": "P2P Drop — Native mobile app (Android & iOS) powered by Capacitor",
  "private": true,
  "scripts": {
    "build": "npm run build:web && npx cap sync",
    "build:web": "npm run build -w packages/web",
    "sync": "npx cap sync",
    "open:android": "npx cap open android",
    "open:ios": "npx cap open ios",
    "run:android": "npx cap run android",
    "run:ios": "npx cap run ios"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/core": "^6.2.0",
    "@capacitor/filesystem": "^6.0.1",
    "@capacitor/ios": "^6.2.0",
    "@capacitor/local-notifications": "^6.1.0",
    "@capacitor/share": "^6.0.2",
    "@capacitor/splash-screen": "^6.0.2",
    "@capacitor/status-bar": "^6.0.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.1"
  }
}
